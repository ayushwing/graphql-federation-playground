type Query {
    user(id: ID!): User
    users: [User!]!
    me: User
}

# @key makes User a federation entity — other subgraphs can reference it
# by id and Apollo Router will route _entities queries back here to resolve them.
type User @key(fields: "id") {
    id: ID!
    username: String!
    email: String!
    name: String!
    bio: String
    avatarUrl: String
    createdAt: String!
}
